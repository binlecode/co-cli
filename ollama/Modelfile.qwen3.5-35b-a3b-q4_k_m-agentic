FROM qwen3.5:35b-a3b

# Qwen3.5-35B-A3B reasoning/tool-calling profile.
# Sources:
# - https://huggingface.co/Qwen/Qwen3.5-35B-A3B
# - https://ollama.com/library/qwen3.5:35b-a3b
#
# co-cli depends on long multi-turn context, and Ollama's OpenAI API ignores
# request-side num_ctx. Bake it into the model.
# 128K is the practical speed/memory sweet spot for agentic use. It avoids
# the extra KV-cache cost of 256K while preserving long-turn tool workflows.
#
# Qwen3.5 official thinking-mode decoding guidance (general tasks):
# temperature 1.0, top_p 0.95, top_k 20, min_p 0, presence_penalty 1.5.
# NOTE: temperature 1.0 differs from Qwen3-2507 thinking (0.6) — intentional.

PARAMETER num_ctx 131072
PARAMETER num_predict 32768
PARAMETER temperature 1.0
PARAMETER top_p 0.95
PARAMETER top_k 20
PARAMETER min_p 0
PARAMETER presence_penalty 1.5
PARAMETER repeat_penalty 1.0
