FROM qwen3:30b-a3b-thinking-2507-q4_k_m

# Qwen3-30B-A3B thinking mode agentic profile (Q4_K_M — lower RAM).
# Source: https://huggingface.co/Qwen/Qwen3-30B-A3B
#
# Inference cost scales with filled context, not the limit.
# Ollama default num_ctx (4096) is far too small for agentic use.
#
# Thinking mode parameters (enable_thinking=True):
#   temperature=0.6, top_p=0.95, top_k=20 — official Qwen3 recommendation.
#   DO NOT use temperature=0 (greedy): causes degenerate thinking loops
#   that exhaust num_predict and hang inference.

PARAMETER num_ctx 262144
PARAMETER num_predict 32768
PARAMETER temperature 0.6
PARAMETER top_p 0.95
PARAMETER top_k 20
PARAMETER repeat_penalty 1.0
