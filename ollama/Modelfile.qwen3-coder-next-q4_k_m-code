FROM qwen3-coder-next:q4_k_m

# Qwen3-Coder-Next coding tooling profile (Q4_K_M).
# Source: https://huggingface.co/Qwen/Qwen3-Coder-Next
#
# Inference cost scales with filled context, not the limit.
# Ollama default num_ctx (4096) is far too small for coding tasks.
# 64K is the practical sweet spot for agentic coding: fits large multi-file
# edits without pre-allocating a 256K KV cache on top of 51GB model weights.
# Params tuned for deterministic coding tooling (lower temp than chat defaults).
# num_predict 32768: leaves 32K for input headroom within the 64K context window.
# num_keep 256: keeps system prompt resident in KV cache across tool calls.

PARAMETER num_ctx 65536
PARAMETER num_predict 32768
PARAMETER temperature 0.6
PARAMETER top_p 0.8
PARAMETER top_k 20
PARAMETER min_p 0.01
PARAMETER repeat_penalty 1.05
PARAMETER num_keep 256
