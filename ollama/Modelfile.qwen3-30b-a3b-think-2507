FROM qwen3:30b-a3b-thinking-2507-q4_k_m

# Qwen3-30B reasoning/tool-calling profile on Ollama's current 30B tag.
# Sources:
# - https://unsloth.ai/docs/models/qwen3.5
#
# co-cli depends on long multi-turn context, and Ollama's OpenAI API ignores
# request-side num_ctx. Bake it into the model.
# 128K is the practical speed/performance sweet spot for agentic use. It avoids
# the extra KV-cache cost of 256K while preserving long-turn tool workflows.
#
# Unsloth official thinking-mode decoding guidance for General Tasks:
# temperature 1.0, top_p 0.95, top_k 20, min_p 0.0, presence_penalty 1.5, repeat_penalty 1.0

PARAMETER num_ctx 131072
PARAMETER num_predict 32768
PARAMETER temperature 1.0
PARAMETER top_p 0.95
PARAMETER top_k 20
PARAMETER min_p 0.0
PARAMETER presence_penalty 1.5
PARAMETER repeat_penalty 1.0
