{
  "llm": {
    "provider": "ollama",
    "host": "http://localhost:11434",
    "model": "qwen3.6:27b-agentic",
    "api_key": null,
    "max_ctx": 131072,
    "ctx_token_budget": 100000
  },
  "knowledge": {
    "search_backend": "hybrid",
    "embedding_provider": "tei",
    "embedding_model": "embeddinggemma",
    "embedding_dims": 1024,
    "embed_api_url": "http://127.0.0.1:8283",
    "cross_encoder_reranker_url": "http://127.0.0.1:8282",
    "tei_rerank_batch_size": 50,
    "chunk_size": 600,
    "chunk_overlap": 80,
    "session_chunk_tokens": 400,
    "session_chunk_overlap": 80,
    "max_artifact_count": 300,
    "decay_after_days": 90,
    "consolidation_enabled": false,
    "consolidation_trigger": "session_end",
    "consolidation_lookback_sessions": 5,
    "consolidation_similarity_threshold": 0.75,
    "character_recall_limit": 3
  },
  "compaction": {
    "compaction_ratio": 0.50,
    "tail_fraction": 0.20,
    "min_proactive_savings": 0.10,
    "proactive_thrash_window": 2
  },
  "memory": {
    "recall_half_life_days": 30
  },
  "web": {
    "fetch_allowed_domains": [],
    "fetch_blocked_domains": [],
    "http_max_retries": 2,
    "http_backoff_base_seconds": 1.0,
    "http_backoff_max_seconds": 8.0,
    "http_jitter_ratio": 0.2
  },
  "shell": {
    "max_timeout": 300,
    "safe_commands": [
      "ls", "tree", "find", "fd",
      "cat", "head", "tail",
      "grep", "rg", "ag",
      "wc", "sort", "uniq", "cut", "tr", "jq",
      "echo", "printf",
      "pwd", "whoami", "hostname", "uname", "date",
      "env", "which", "file", "stat", "id", "du", "df",
      "git status", "git diff", "git log", "git show",
      "git branch", "git tag", "git blame"
    ]
  },
  "observability": {
    "log_level": "INFO",
    "log_max_size_mb": 5,
    "log_backup_count": 3
  },
  "tools": {
    "result_persist_chars": 50000
  },

  "obsidian_vault_path": "",
  "google_credentials_path": "",
  "brave_search_api_key": "",
  "knowledge_path": "",

  "theme": "light",
  "personality": "tars",
  "reasoning_display": "summary",
  "tool_retries": 3,
  "doom_loop_threshold": 3,
  "max_reflections": 3,

  "mcp_servers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "approval": "auto"
    }
  }
}
