{
  "llm_provider": "gemini",
  "gemini_api_key": "",
  "gemini_model": "gemini-2.0-flash",
  "ollama_host": "http://localhost:11434",
  "role_models": {
    "reasoning": [
      {
        "model": "qwen3.5:35b-a3b-think",
        "api_params": {
          "temperature": 1.0,
          "top_p": 0.95,
          "top_k": 20,
          "presence_penalty": 1.5,
          "repeat_penalty": 1.0,
          "num_predict": 32768
        }
      }
    ],
    "summarization": [
      "qwen3.5:35b-a3b-q4_k_m-nothink"
    ],
    "coding": [
      {
        "model": "qwen3.5:35b-a3b-code",
        "api_params": {
          "temperature": 0.6,
          "top_p": 0.95,
          "top_k": 20,
          "presence_penalty": 0.0,
          "repeat_penalty": 1.0,
          "num_predict": 32768
        }
      }
    ],
    "research": [
      {
        "model": "qwen3.5:35b-a3b-q4_k_m-research",
        "api_params": {
          "think": false
        }
      }
    ],
    "analysis": [
      "qwen3.5:35b-a3b-q4_k_m-nothink"
    ]
  },

  "obsidian_vault_path": "",
  "google_credentials_path": "",
  "brave_search_api_key": "",
  "web_fetch_allowed_domains": [],
  "web_fetch_blocked_domains": [],
  "web_http_max_retries": 2,
  "web_http_backoff_base_seconds": 1.0,
  "web_http_backoff_max_seconds": 8.0,
  "web_http_jitter_ratio": 0.2,
  "web_policy": {
    "search": "allow",
    "fetch": "allow"
  },

  "docker_image": "co-cli-sandbox",
  "theme": "light",
  "tool_retries": 3,
  "max_request_limit": 25,

  "tool_output_trim_chars": 2000,
  "sandbox_backend": "auto",
  "sandbox_max_timeout": 600,
  "sandbox_network": "none",
  "sandbox_mem_limit": "1g",
  "sandbox_cpus": 1,

  "shell_safe_commands": [
    "ls", "tree", "find", "fd",
    "cat", "head", "tail",
    "grep", "rg", "ag",
    "wc", "sort", "uniq", "cut", "jq",
    "echo", "printf",
    "pwd", "whoami", "hostname", "uname", "date",
    "env", "which", "file", "id", "du", "df",
    "git status", "git diff", "git log", "git show",
    "git branch", "git tag", "git blame"
  ]
}
